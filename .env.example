# Email Configuration
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_contraseña_o_app_password
PORT=3000

# Entorno: 'production' habilita la verificación real de Turnstile
NODE_ENV=development

# Cloudflare Turnstile Keys
TURNSTILE_SECRET_KEY=tu_clave_secreta
TURNSTILE_SITE_KEY=tu_clave_de_sitio

# Orígenes permitidos para CORS, separados por comas
ALLOWED_ORIGINS=http://localhost:3000,https://viangsolution.com,https://www.viangsolution.com
